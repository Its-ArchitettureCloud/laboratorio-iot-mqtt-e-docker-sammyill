    {
        "id": "bdc098e8f1234b9a",
        "type": "function",
        "z": "5e254318e26697a3",
        "name": "data for dashboard",
        "func": "const payload = msg.payload;\n\nlet temperatura = payload?.temperatura;\n\nif (temperatura === undefined && payload?.fields) {\n    temperatura = payload.fields.temperatura;\n}\n\ntemperatura = Number(temperatura);\n\nif (!Number.isFinite(temperatura)) {\n    node.warn(\"Invalid temperatura: \" + JSON.stringify(payload));\n    return null;\n}\n\nmsg.payload = temperatura;\nmsg.topic = payload?.tags?.sensor || payload?.sensor || \"temperature\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 1360,
        "wires": [
