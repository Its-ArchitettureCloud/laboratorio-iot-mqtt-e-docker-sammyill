                "3486aa33c94e2214",
                "2beb3f3a87741bf1"
            ]
        ]
    },
    {
        "id": "a5afe523dc0ca851",
        "type": "function",
        "z": "5e254318e26697a3",
        "name": "data for nodered",
        "func": "const payload = msg.payload;\n\n  let temperatura = payload?.temperatura;\n  let sensor = payload?.sensor;\n  let type = payload?.type;\n  let unit = payload?.unit;\n\n  if (payload?.fields) {\n      temperatura = payload.fields.temperatura;\n  }\n\n  if (payload?.tags) {\n      sensor = payload.tags.sensor;\n      type = payload.tags.type;\n      unit = payload.tags.unit;\n  }\n\n  temperatura = Number(temperatura);\n\n  if (!Number.isFinite(temperatura)) {\n      node.warn(\"Invalid temperatura: \" + JSON.stringify(payload));\n      return null;\n  }\n\n  msg.payload = [\n      {\n          temperatura: temperatura\n      },\n      {\n          sensor: sensor || \"unknown\",\n          type: type || \"temperature\",\n          unit: unit || \"celsius\"\n      }\n  ];\n\n  return msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 1460,
        "wires": [
